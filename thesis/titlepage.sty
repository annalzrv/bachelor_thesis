\newif\if@hasConsultant
\newif\if@hasCoAdvisor
\@hasCuratorfalse
\@hasConsultantfalse
\@hasCoAdvisorfalse

% ---------- signature field helper ----------
% \@sgnfield{width}{filled content (e.g. printed name)}{caption under the line}
\newcommand{\@sgnfield}[3]{%
  \parbox[t]{#1}{%
    \hbox to #1{\hfil #2 \hfil}%
    \vskip 2pt%
    \hrule%
    \vskip 2pt%
    \hbox to #1{\hfil {\fontsize{9}{11}\selectfont #3}\hfil}%
  }%
}

% ---------- setters ----------
\newcommand{\setTitle}[1]{\renewcommand{\@vtTitle}{#1}}
\newcommand{\setTitleRu}[1]{\renewcommand{\@vtTitleRu}{#1}}
\newcommand{\setStudent}[1]{\renewcommand{\@vtStudent}{#1}}
\newcommand{\setStudentGroup}[1]{\renewcommand{\@vtStudentGroup}{#1}}
