% ---------- title page ----------
\newcommand{\makeTitlePage}{%
\begin{titlepage}
\selectlanguage{english}

{\setstretch{1.0}
\begin{center}
Federal State Autonomous Educational Institution for Higher Education\\[2pt]
National Research University\\[2pt]
Higher School of Economics
\end{center}
}

\vspace{1.5em}

\begin{center}
\@vtFaculty\\[6pt]
\@vtProgramme
\end{center}

\vspace{6em}

\begin{center}
{\bf BACHELOR'S THESIS}\\[0.5em]
({\@vtProjectType})\\[2em]
{\bf \@vtTitle}
\end{center}

\if\relax\detokenize{\@vtTitleRu}\relax\else
\vspace{1em}
\begin{center}
\selectlanguage{russian}\textit{\@vtTitleRu}\selectlanguage{english}
\end{center}
\fi

\vspace{3em}

\noindent Submitted by\\[2pt]
student of group \@vtStudentGroup, \@vtStudentYear,

\vspace{1.2em}

\noindent\@sgnfield{8cm}{\@vtStudent}{Name}

\vspace{0.6em}

\noindent\@sgnfield{8cm}{}{Signature, Date}

\vspace{1.5em}

\noindent Approved by Supervisor:\\[6pt]
\@vtAdvisorDegree, \@vtAdvisorTitle, \@vtAdvisor

\if@hasCurator
\vspace{1.5em}
\noindent Curator:\\[6pt]
\@vtCuratorDegree, \@vtCuratorTitle, \@vtCurator
\fi

\if@hasConsultant
\vspace{1.5em}
\noindent Сonsultant:\\[6pt]
\@vtConsultantDegree, \@vtConsultantTitle, \@vtConsultant
\fi

\vspace{\fill}

\begin{center}
Moscow \@vtYear
\end{center}

\thispagestyle{empty}
\end{titlepage}
}
