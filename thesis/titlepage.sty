\newcommand{\setAdvisorDegree}[1]{\renewcommand{\@vtAdvisorDegree}{#1}}
\newcommand{\setAdvisorAffiliation}[1]{\renewcommand{\@vtAdvisorAffiliation}{#1}}
\newcommand{\setCurator}[1]{\@hasCuratortrue\renewcommand{\@vtCurator}{#1}}
\newcommand{\setCuratorTitle}[1]{\renewcommand{\@vtCuratorTitle}{#1}}
\newcommand{\setCuratorDegree}[1]{\renewcommand{\@vtCuratorDegree}{#1}}
\newcommand{\setConsultant}[1]{\@hasConsultanttrue\renewcommand{\@vtConsultant}{#1}}
